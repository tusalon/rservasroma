Subject: [PATCH] Fix identidad del panel admin en iOS

---
 admin-login.html | 13 ++++++++--
 admin.html       | 73 ++++++++++++++++++++++--------------------------
 sw.js            | 32 +++++++++++++--------
 3 files changed, 67 insertions(+), 51 deletions(-)

diff --git a/admin-login.html b/admin-login.html
index a3f60df..1962c9d 100644
--- a/admin-login.html
+++ b/admin-login.html
@@ -5,6 +5,14 @@
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Rservasroma — Acceso</title>
 
+  <script>
+    // Preparar el Service Worker desde el login. Así, al llegar al panel, iOS
+    // ya puede obtener el manifest administrativo específico del negocio.
+    if ('serviceWorker' in navigator) {
+      navigator.serviceWorker.register('sw.js?v=20260717-ios-admin').catch(function() {});
+    }
+  </script>
+
   <script src="vendor/bcrypt.min.js"></script>
   <script>
     window.addEventListener('load', function() {
@@ -253,6 +261,8 @@
         var campoUsuario = document.getElementById('username');
         if (campoUsuario && !campoUsuario.value) {
           campoUsuario.value = slugParam;
+          campoUsuario.readOnly = true;
+          campoUsuario.title = 'Este acceso pertenece al negocio ' + slugParam;
           document.getElementById('password').focus();
         }
       }
@@ -322,7 +332,8 @@
         mensaje.textContent = window.t('✅ Bienvenida, {nombre}...', { nombre: negocio.nombre });
 
         setTimeout(function() {
-          window.location.href = negocio.configurado ? 'admin.html?s=' + negocio.slug : 'setup-wizard.html?s=' + negocio.slug;
+          var slugDestino = encodeURIComponent(negocio.slug);
+          window.location.href = negocio.configurado ? 'admin.html?s=' + slugDestino : 'setup-wizard.html?s=' + slugDestino;
         }, 900);
 
       } catch (error) {
diff --git a/admin.html b/admin.html
index e2ca5e5..e6eb4e8 100644
--- a/admin.html
+++ b/admin.html
@@ -3,54 +3,49 @@
 <head>
     <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1.0">
-    <link rel="manifest" href="manifest.json">
-    <script>
-      (function() {
-        try {
-          // iOS no soporta manifests blob para "Añadir a pantalla de inicio":
-          // caía al manifest.json estático (orientado a clientas) y el ícono
-          // del admin abría la app de clientas. Sin <link rel="manifest">,
-          // iOS usa la URL ACTUAL (admin.html?s=slug) como inicio, que es
-          // exactamente lo que el ícono del panel debe abrir.
-          if (/iPhone|iPad|iPod/i.test(navigator.userAgent)) {
-            var linkIOS = document.querySelector('link[rel="manifest"]');
-            if (linkIOS) linkIOS.remove();
-            return;
-          }
-          var nombre = localStorage.getItem('negocioNombre') || '';
-          var slug   = localStorage.getItem('negocioSlug')   || '';
-          if (!nombre || !slug) return;
-          var m = {
-            name:             nombre,
-            short_name:       nombre.split(/\s+/).slice(0,2).join(' '),
-            start_url:        'admin.html?s=' + slug,
-            scope:            './',
-            display:          'standalone',
-            theme_color:      '#FF1493',
-            background_color: '#1A1A1A',
-            icons: [
-              { src: 'icons/icon-192x192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
-              { src: 'icons/icon-512x512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' }
-            ]
-          };
-          var blob = new Blob([JSON.stringify(m)], { type: 'application/json' });
-          var link = document.querySelector('link[rel="manifest"]');
-          if (link) link.href = URL.createObjectURL(blob);
-        } catch(e) {}
-      })();
-    </script>
     <meta name="theme-color" content="#ec4899">
     <meta name="mobile-web-app-capable" content="yes">
     <meta name="apple-mobile-web-app-capable" content="yes">
     <meta name="apple-mobile-web-app-status-bar-style" content="default">
+    <meta name="apple-mobile-web-app-title" id="apple-admin-title" content="Rservasroma Admin">
     <link rel="apple-touch-icon" href="icons/icon-192x192.png">
     <title>Panel de Administración</title>
     <script>
+      (function() {
+        var params = new URLSearchParams(window.location.search);
+        var slug = (params.get('s') || localStorage.getItem('adminSlug') || localStorage.getItem('negocioSlug') || '').toLowerCase().trim();
+        var nombre = (localStorage.getItem('negocioNombre') || slug || 'Rservasroma Admin').trim();
+
+        // Fallback nativo de iOS: si el manifest todavía no está controlado por
+        // el Service Worker, Safari usa el título, la URL actual y apple-touch-icon.
+        document.title = nombre + ' — Administración';
+        var appleTitle = document.getElementById('apple-admin-title');
+        if (appleTitle) appleTitle.setAttribute('content', nombre);
+
+        function enlazarManifestAdmin() {
+          if (!slug || !navigator.serviceWorker || !navigator.serviceWorker.controller) return;
+          var link = document.getElementById('admin-manifest-link');
+          if (!link) {
+            link = document.createElement('link');
+            link.id = 'admin-manifest-link';
+            link.rel = 'manifest';
+            document.head.appendChild(link);
+          }
+          link.href = 'manifest.json?mode=admin&s=' + encodeURIComponent(slug) +
+            '&n=' + encodeURIComponent(nombre) + '&v=20260717-ios-admin';
+        }
+
         if ('serviceWorker' in navigator) {
-            window.addEventListener('load', function() {
-                navigator.serviceWorker.register('sw.js').catch(function() {});
-            });
+          navigator.serviceWorker.addEventListener('controllerchange', enlazarManifestAdmin);
+          navigator.serviceWorker.register('sw.js?v=20260717-ios-admin')
+            .then(function(registration) {
+              registration.update().catch(function() {});
+              return navigator.serviceWorker.ready;
+            })
+            .then(enlazarManifestAdmin)
+            .catch(function() {});
         }
+      })();
     </script>
     <script src="vendor/tailwind-browser.js"></script>
     <script src="vendor/react.production.min.js"></script>
diff --git a/sw.js b/sw.js
index c6cdde0..9829928 100644
--- a/sw.js
+++ b/sw.js
@@ -1,6 +1,6 @@
 // sw.js - Service Worker para Rservasroma
 
-const CACHE_NAME = 'rservasroma-v18';
+const CACHE_NAME = 'rservasroma-v19-ios-admin';
 const BASE = '/rservasroma';
 
 const urlsToCache = [
@@ -141,20 +141,27 @@ self.addEventListener('fetch', event => {
   if (BYPASS.some(b => event.request.url.includes(b))) return;
   if (event.request.method !== 'GET') return;
 
-  // Manifest dinámico por salón — sin blob URLs
+  // Manifest dinámico por salón — cliente y administración tienen identidades
+  // y URLs de inicio distintas para que iOS nunca abra el panel equivocado.
   const reqUrl = new URL(event.request.url);
   if (reqUrl.pathname === `${BASE}/manifest.json` && reqUrl.searchParams.has('s')) {
     const slug   = reqUrl.searchParams.get('s') || '';
     const nombre = reqUrl.searchParams.get('n') || slug;
+    const esAdmin = reqUrl.searchParams.get('mode') === 'admin';
     const BASE_URL = 'https://tusalon.github.io' + BASE;
+    const appUrl = esAdmin
+      ? BASE_URL + '/admin.html?s=' + encodeURIComponent(slug)
+      : BASE_URL + '/?s=' + encodeURIComponent(slug);
     const manifest = {
-      // id estable por salón: si una clienta instala dos salones del mismo
-      // origen, Android los trata como apps distintas en vez de pisarse.
-      id: BASE_URL + '/?s=' + encodeURIComponent(slug),
+      // El modo forma parte del id: un mismo negocio puede tener instaladas la
+      // app de clientas y la app administrativa sin que una sustituya a la otra.
+      id: appUrl,
       name: nombre,
       short_name: nombre.split(/\s+/).slice(0, 2).join(' '),
-      description: 'Reserva tu turno online en ' + nombre,
-      start_url: BASE_URL + '/?s=' + encodeURIComponent(slug),
+      description: esAdmin
+        ? 'Panel de administración de ' + nombre
+        : 'Reserva tu turno online en ' + nombre,
+      start_url: appUrl,
       scope: BASE_URL + '/',
       display: 'standalone',
       theme_color: '#FF1493',
@@ -162,17 +169,20 @@ self.addEventListener('fetch', event => {
       icons: [
         { src: BASE_URL + '/icons/icon-192x192.png', sizes: '192x192', type: 'image/png', purpose: 'any maskable' },
         { src: BASE_URL + '/icons/icon-512x512.png', sizes: '512x512', type: 'image/png', purpose: 'any maskable' }
-      ],
+      ]
+    };
+
+    if (!esAdmin) {
       // Android: mantener presionado el ícono → acceso directo a Mis Citas.
-      shortcuts: [
+      manifest.shortcuts = [
         {
           name: 'Mis Citas',
           short_name: 'Mis Citas',
           url: BASE_URL + '/?s=' + encodeURIComponent(slug) + '&ir=citas',
           icons: [{ src: BASE_URL + '/icons/icon-192x192.png', sizes: '192x192', type: 'image/png' }]
         }
-      ]
-    };
+      ];
+    }
     event.respondWith(new Response(JSON.stringify(manifest), {
       headers: { 'Content-Type': 'application/manifest+json', 'Cache-Control': 'no-cache' }
     }));
